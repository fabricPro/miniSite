{
  "name": "numune-master-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start:all": "docker compose up -d postgres && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:backup": "tsx --env-file=.env.local scripts/backup.ts",
    "import:excel": "tsx --env-file=.env.local scripts/import-excel.ts",
    "import:missing": "tsx --env-file=.env.local scripts/import-missing.ts",
    "import:numune": "tsx --env-file=.env.local scripts/import-numune.ts",
    "import:boyane": "tsx --env-file=.env.local scripts/import-boyane.ts",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
