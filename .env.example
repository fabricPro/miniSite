# =============================================================================
# Numune Master — env örneği
# =============================================================================
# .env.local dosyasını bu örneği kopyalayarak oluştur, gerçek değerleri yaz.
# Production (Vercel) değerleri Vercel dashboard'a girilir, .env.local'a değil.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Lokal geliştirme: docker compose ile çalışan Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/numune_master

# Production (Neon): Pooled URL kullan (-pooler içerir, serverless için optimize)
# Örnek: postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/numune_master?sslmode=require
# DATABASE_URL=

# Migration / db:push komutları için DIRECT URL gerekir (pooled değil)
# Sadece lokal'de çalışan db:* komutları için, Vercel runtime'a gerekmez
# DATABASE_URL_DIRECT=

# Lokal docker compose için (Vercel'de gerekmez)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=numune_master
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Auth.js v5
# -----------------------------------------------------------------------------

# Geliştirme için: rastgele uzun string
# Production için: openssl rand -base64 32 ile üret, Vercel env'e koy
AUTH_SECRET=dev-secret-change-for-prod-please-use-openssl-rand-base64-32

# Auth.js v5 Vercel'de NEXTAUTH_URL'i otomatik tespit eder, ama lokal için gerekli
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# ERP Bridge (gelecek sprint — şimdilik boş)
# -----------------------------------------------------------------------------

# İşyerinde MSSQL ERP'ye bağlanmak için (sync script kullanır, app değil)
# Format: Server=10.x.x.x;Database=ERP;User Id=numune_ro;Password=xxx;TrustServerCertificate=true
ERP_DATABASE_URL=
ERP_DB_TYPE=mssql
